<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delete</title>
</head>
<body>

  <h1>Delete Event</h1>
  
  <% if (error !== '') { %>
    <p style="color:red">⚠️ <%= error %></p>
  <% } %>

  <% if (success === '' && Object.keys(result).length !== 0) { %>
    <p><strong>⚠️ This action cannot be undone! Are you sure you want to delete this event?</strong></p>
    
    <table>
      <tr>
        <th>Title</th>
        <td><%= result.title %></td>
      </tr>
      <tr>
        <th>Description</th>
        <td><%= result.description %></td>
      </tr>
      <tr>
        <th>Date</th>
        <td><%= date %></td>
      </tr>
      <tr>
        <th>Location</th>
        <td><%= result.location %></td>
      </tr>
      <tr>
        <th>Category</th>
        <td><%= result.category %></td>
      </tr>
    </table>
    
    <br>
    <form action="/delete-event" method="POST">
      <input type="hidden" name="_id" value="<%= result._id %>">
      <button type="submit">🗑️ Confirm Delete</button>
    </form>
  <% } %>

  <% if (success !== '') { %>
    <p style="color:green">✅ <%= success %></p>
  <% } %>
    <br>
  <a href="/events">← Back to Events</a>

</body>
</html>
