<%- include("common/header") %>
  <% const students = data.filter(account => account.role === 'Student'); %>
  <% const admins = data.filter(account => account.role === 'Admin'); %>
  <table width="80%" align="center">
    <tr>
      <td>
  <h1>Welcome, <%= user.name %> 👋</h1>

  <hr>

  <h2>🚩 Reports</h2>
  <p>
    <a href="/reports">View Reports</a>
  </p>

  <hr>

  <h2>Students (<%= students.length %>)</h2>
  <table border="1" cellpadding="8" cellspacing="0" style="border-collapse:collapse;">
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Password</th>
      <th>Role</th>
      <th colspan="2">Actions</th>
      
    </tr>
    <% students.forEach(user => {%>
      <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td>********</td>
          <td><%= user.role %></td>
          <td><a href="/user/admin?email=<%= user.email %>#editform">Edit</a> | <a href="/user/admin?delete=<%= user.email %>#confirmdelete">Delete</a></td>
      </tr>
    <%}); %>
  </table>
    
  <br>

  <h2>Admins (<%= admins.length-1 %>)</h2>
  <table border="1" cellpadding="8" cellspacing="0" style="border-collapse:collapse;">
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Password</th>
      <th>Role</th>
      <th colspan="2">Actions</th>
    </tr>
    <% admins.forEach(admin => {%>
      <% if(admin.email!=user.email){ %>
      <tr>
          <td><%= admin.name %></td>
          <td><%= admin.email %></td>
          <td>********</td>
          <td><%= admin.role %></td>
          <td><a href="/user/admin?email=<%= admin.email %>#editform">Edit</a> | <a href="/user/admin?delete=<%= admin.email %>#confirmdelete">Delete</a></td>
      </tr>
      <% } %>
    <%}); %>
  </table>


<% if(edit){ %>
    <div id="editform">

    <h4>Edit User</h4>
    
      <form action="/user/edit-user" method="post">
        <table cellpadding="8" cellspacing="0">
        <tr>
          <td>Name:*</td>
          <td><input type="text" name="name" value="<%= edit.name %>"></td>
        </tr>
        <tr>
          <td>Email: </td>
          <td><%= edit.email %></td>
          <input type="hidden" name="email" value="<%= edit.email %>">
        </tr>
        <tr>
          <td>Password: </td>
          <td><input type="text" name="password" placeholder="leave empty if no change"></td>
        </tr>
        <tr>
          <td>Role:*</td>
          <td>  
          <select name="role" class="form-control">
            <option value="Student" <%=edit.role=="Student"? "selected" : ""%>>Student</option>
            <option value="Admin" <%=edit.role=="Admin"? "selected" : ""%>>Admin</option>
          </select></td>
        </tr>
          </table><br>
          <button type="submit">Update</button>
        </form>
        
    </table>
        
        
    </div>

  <% } %>
  <% if (del) { %>
    <div id="confirmdelete">
      <p><strong>⚠️ This action cannot be undone! Are you sure you want to delete this account?</strong></p>
    <form action="/user/delete-user" method="get">
        <input type="hidden" name="email" value="<%= del %>">
        <button type="submit">🗑️ Confirm Delete</button>
        <a href="/user/admin"><button type="button">Cancel</button></a>
    </form>
    </div>
  <% } %>
  <% if(error){ %>
    <p style="color:red"><%= error %></p>
    <% } %>
  <% if(success){ %>
    <p style="color:green"><%= success %></p>
    <% } %>
      </td>
    </tr>
  </table>
  </center>
</body>
</html>
