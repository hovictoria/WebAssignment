<%- include("common/header") %>

    <h1>My Bookmarked Events</h1>

    <% if (error) { %>
        <p><%= error %></p>
    <% } %>

    <% if (success) { %>
        <p><%= success %></p>
    <% } %>

    <a href="/events">Back to Events</a>

    <br><br>

    <% if (!bookmarks || bookmarks.length === 0) { %>
        <p>No bookmarked events yet.</p>
    <% } else { %>
        <table border="1" cellpadding="8" cellspacing="0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Location</th>
                    <th>Category</th>
                    <th>Saved At</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% bookmarks.forEach((bookmark) => { %>
                    <tr>
                        <td>
                            <% if (bookmark.eventDetails) { %>
                                <a href="/event-details?_id=<%= bookmark.eventId %>"><%= bookmark.eventDetails.title %></a>
                            <% } else { %>
                                Event
                            <% } %>
                        </td>
                        <td><%= bookmark.eventDetails ? bookmark.eventDetails.date : 'N/A' %></td>
                        <td><%= bookmark.eventDetails ? bookmark.eventDetails.location : 'N/A' %></td>
                        <td><%= bookmark.eventDetails ? bookmark.eventDetails.category : 'N/A' %></td>
                        <td><%= new Date(bookmark.savedAt).toLocaleDateString() %></td>
                        <td>
                            <form action="/bookmarks/<%= bookmark.bookmarkId %>/update" method="POST">
                                <input type="text" name="notes" value="<%= bookmark.notes %>">
                                <button type="submit">Save Notes</button>
                            </form>
                        </td>
                        <td>
                            <form action="/bookmarks/<%= bookmark.bookmarkId %>/delete" method="POST">
                                <button type="submit">Remove</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>

    </center>
</body>
</html>
