<%- include("common/header") %>

<table width="700" align="center" border="1" cellpadding="12" cellspacing="0">
  <tr>
    <td align="left">
<h1>Report Event</h1>

<% if (error) { %>
  <p style="color:red"><%= error %></p>
<% } %>

<% if (success) { %>
  <p style="color:green"><%= success %></p>
<% } %>

<% if (!success) { %>
  <form action="/report-event" method="post">
    <input type="hidden" name="eventId" value="<%= event._id %>">

    <table>
      <tr>
        <th align="left">Event:</th>
        <td><%= event.title %></td>
      </tr>
      <tr>
        <th align="left">Reason:</th>
        <td>
          <select name="reason">
            <option value="">-- Select a category --</option>
            <% reportReasons.forEach(reportReason => { %>
              <option value="<%= reportReason %>" <%= reason === reportReason ? 'selected' : '' %>><%= reportReason %></option>
            <% }) %>
          </select>
        </td>
      </tr>
      <tr>
        <th align="left">Details:</th>
        <td><textarea name="details" rows="5" cols="50"><%= details %></textarea></td>
      </tr>
    </table>

    <br>

    <button type="submit">Submit Report</button>
  </form>
<% } %>

<br>

<a href="/events">← Back to Events</a>
    </td>
  </tr>
</table>

    </center>
</body>
</html>
