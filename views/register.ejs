<%- include("common/header") %>
   
    <h1 style="text-align: center;">Register</h1>
    <div style=" font-size:20px; width: 100%; padding-left:490px;"><br>

    <form action="/register" method="post">

        <label for="email">Email: </label><br><input type="email" size="25" name="email" placeholder="Enter email" value="<%=email%>"><br><br>
        
        <label for="password">Password:</label><br><input type="password" size="25" name="password" placeholder="Enter password"><br><br>
        
        <label for="confirmPassword">Confirm Password:</label><br><input type="password" size="25" name="confirmpassword" placeholder="Confirm password"><br><br>

        <button type="submit">Register</button><br><br>

        <span>Registered? </span><a href="/login">Log In!</a>

    </form>
    <% if(errors.length!=0){ %>
        <ul style="color: red">
        <% errors.forEach(error => { %>
            <li><%= error %></li>
            <% }) %>
        </ul>
    <% } %>
    </div>

</body>
</html>