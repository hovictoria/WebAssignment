<%- include("common/header") %>


    <h1>Campus Events</h1>

    <a href="/create-event">Create Event</a>

    <hr>

    <form method="GET" action="/events">
        <div>
            <label>Keyword:</label>
            <input type="text" name="keyword" value="<%= keyword %>">
        </div>

        <br>

        <div>
            <label>Category:</label>
            <select name="category">
                <option value="">All</option>
                <option value="Academic" <%= category === 'Academic' ? 'selected' : '' %>>Academic</option>
                <option value="Social" <%= category === 'Social' ? 'selected' : '' %>>Social</option>
                <option value="Sports" <%= category === 'Sports' ? 'selected' : '' %>>Sports</option>
                <option value="Workshop" <%= category === 'Workshop' ? 'selected' : '' %>>Workshop</option>
                <option value="Other" <%= category === 'Other' ? 'selected' : '' %>>Other</option>
            </select>
        </div>

        <br>

        <div>
            <label>Location:</label>
            <input type="text" name="location" value="<%= location %>">
        </div>

        <br>

        <div>
            <label>Date:</label>
            <input type="date" name="date" value="<%= date %>">
        </div>

        <br>

        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <button type="submit">Search / Filter</button>
                <a href="/events">Clear</a>
            </div>

            <div>
                <label>Sort by:</label>
                <select name="sortBy" onchange="this.form.submit()">
                    <option value="date" <%= sortBy === 'date' ? 'selected' : '' %>>Date</option>
                    <option value="title" <%= sortBy === 'title' ? 'selected' : '' %>>Title (A-Z)</option>
                    <option value="titleDesc" <%= sortBy === 'titleDesc' ? 'selected' : '' %>>Title (Z-A)</option>
                </select>
            </div>
        </div>
    </form>

    <hr>

    <% if (events.length === 0) { %>
        <p>No events found.</p>
    <% } else { %>
        <table border="1" cellpadding="8" cellspacing="0" style="width:100%; border-collapse:collapse;">
            <thead>
                <tr>
                    <th>Name of Event</th>
                    <th>Description</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Location</th>
                    <th>Category</th>
                    <th>Organiser</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% events.forEach(event => { %>
                    <tr>
                        <td><%= event.title %></td>
                        <td><%= event.description %></td>
                        <td><%= new Date(event.date).toDateString() %></td>
                        <td><%= event.time || '-' %></td>
                        <td><%= event.location %></td>
                        <td><%= event.category %></td>
                        <td><%= event.organiser %></td>
                        <td>
                            <% const canEdit = user && (user.role === 'Admin' || String(event.organiser) === String(user.id)); %>
                            <% const canDelete = user && (user.role === 'Admin' || String(event.organiser) === String(user.id)); %>
                            <% let hasAction = false; %>
                            <% if (canEdit) { %>
                                <a href="/update-event?_id=<%= event._id %>">Edit</a>
                                <% hasAction = true; %>
                            <% } %>
                            <% if (canDelete) { %>
                                <% if (hasAction) { %>|<% } %>
                                <a href="/delete-event?_id=<%= event._id %>">Delete</a>
                                <% hasAction = true; %>
                            <% } %>
                            <% if (user && user.role === 'Student') { %>
                                <% if (hasAction) { %>|<% } %>
                                <a href="/rsvp?_id=<%= event._id %>">RSVP</a>
                                <% hasAction = true; %>
                            <% } %>
                            <% if (user) { %>
                                <% if (hasAction) { %>|<% } %>
                                <a href="/report-event?_id=<%= event._id %>">Report</a>
                                <% hasAction = true; %>
                            <% } %>

                            <% if (user) { %>
                                <% if (hasAction) { %>|<% } %>
                                <button onclick="toggleBookmark('<%= event._id %>', this)">
                                    ☆ Bookmark
                                </button>
                                <% hasAction = true; %>
                            <% } %>


                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
<script>
async function toggleBookmark(eventId, btn) {
  try {
    const response = await fetch('/api/bookmarks/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ eventId })
    });

    const data = await response.json();

    if (data.success) {
      btn.textContent = '★ Bookmarked';
      btn.style.background = '#4CAF50';
    } else {
      alert(data.error);
    }
  } catch (error) {
    alert('Error: ' + error.message);
  }
}
</script>
  
    
</body>
</html>