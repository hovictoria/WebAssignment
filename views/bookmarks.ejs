<%- include("common/header") %>

    <table width="80%" align="center">
        <tr>
            <td align="left">
    <h1>My Bookmarked Events</h1>

    <% if (error) { %>
        <p style="color:red"><%= error %></p>
    <% } %>

    <% if (success) { %>
        <p style="color:green"><%= success %></p>
    <% } %>

    <a href="/events">Back to Events</a>

    <br><br>

    <% if (!bookmarks || bookmarks.length === 0) { %>
        <p>No bookmarked events yet.</p>
    <% } else { %>
        <table border="1" cellpadding="8" cellspacing="0" width="100%">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Location</th>
                    <th>Category</th>
                    <th>Saved At</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% bookmarks.forEach((bookmark) => { %>
                    <tr>
                        <td>
                            <% if (bookmark.eventDetails) { %>
                                <a href="/events/event-details?_id=<%= bookmark.eventId %>"><%= bookmark.eventDetails.title %></a>
                            <% } else { %>
                                Event
                            <% } %>
                        </td>
                        <td><%= bookmark.eventDetails ? new Date(bookmark.eventDetails.date).toDateString() : 'N/A' %></td>
                        <td><%= bookmark.eventDetails ? bookmark.eventDetails.location : 'N/A' %></td>
                        <td><%= bookmark.eventDetails ? bookmark.eventDetails.category : 'N/A' %></td>
                        <td><%= new Date(bookmark.savedAt).toDateString() %></td>
                        <td>
                            <form action="/bookmarks/<%= bookmark._id %>/update" method="POST">
                                <input type="text" name="notes" value="<%= bookmark.notes %>">
                                <button type="submit">Save Notes</button>
                            </form>
                        </td>
                        <td>
                            <form action="/bookmarks/<%= bookmark._id %>/delete" method="POST">
                                <button type="submit">Remove</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
            </td>
        </tr>
    </table>

    </center>
</body>
</html>
