<%- include("common/header") %>

<table width="700" align="center" border="1" cellpadding="12" cellspacing="0">
  <tr>
    <td align="left">
<h1>RSVP for Event</h1>

<% if (error) { %>
  <p><%= error %></p>
<% } %>

<% if (success) { %>
  <p><%= success %></p>
<% } %>

<h2><%= event.title %></h2>
<table border="1" cellpadding="8" cellspacing="0">
  <tr>
    <th>Date</th>
    <td><%= new Date(event.date).toDateString() %></td>
  </tr>
  <tr>
    <th>Time</th>
    <td><%= event.time || '-' %></td>
  </tr>
  <tr>
    <th>Location</th>
    <td><%= event.location %></td>
  </tr>
  <tr>
    <th>Category</th>
    <td><%= event.category %></td>
  </tr>
  <tr>
    <th>Description</th>
    <td><%= event.description %></td>
  </tr>
</table>

<hr>

<form action="/create-rsvp" method="POST">
  <input type="hidden" name="eventId" value="<%= event._id %>">

  <label>Status:</label>
  <select name="status">
    <option value="Going" <%= myRsvp && myRsvp.status === 'Going' ? 'selected' : '' %>>Going</option>
    <option value="Maybe" <%= myRsvp && myRsvp.status === 'Maybe' ? 'selected' : '' %>>Maybe</option>
    <option value="Not going" <%= myRsvp && myRsvp.status === 'Not going' ? 'selected' : '' %>>Not going</option>
  </select>

  <br><br>

  <label>Note:</label>
  <textarea name="note"><%= myRsvp ? myRsvp.note : '' %></textarea>

  <br><br>

  <button type="submit">
    <%= myRsvp ? 'Update RSVP' : 'Submit RSVP' %>
  </button>
</form>

<hr>

<h2>Attendees</h2>

<% if (!rsvps || rsvps.length === 0) { %>
  <p>No RSVPs yet.</p>
<% } else { %>
  <table border="1" cellpadding="8" cellspacing="0" style="width:100%; border-collapse:collapse;">
    <thead>
      <tr>
        <th>User</th>
        <th>Status</th>
        <th>Note</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% rsvps.forEach(rsvp => { %>
        <tr>
          <td><%= rsvp.user.name %></td>
          <td><%= rsvp.status %></td>
          <td><%= rsvp.note || '-' %></td>
          <td><%= new Date(rsvp.rsvpDate).toDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<br>
<a href="/events">Back to Events</a>

    </td>
  </tr>
</table>
    </center>
</body>
</html>
