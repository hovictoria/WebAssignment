<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>

    <h1><%= event.title %></h1>
    <table border="1">
        <tr>
            <th>Description:</th>
            <td><%= event.description %></td>
        </tr>
        <tr>
            <th>Date:</th>
            <td><%= new Date(event.date).toDateString() %></td>
        </tr>
        <tr>
            <th>Time:</th>
            <td><%= event.time || '-' %></td>
        </tr>
        <tr>
            <th>Location:</th>
            <td><%= event.location %></td>
        </tr>
        <tr>
            <th>Category:</th>
            <td><%= event.category %></td>
        </tr>
        <tr>
            <th>Organiser:</th>
            <td><%= organiser.name %></td>
        </tr>
        
    </table>
    <br>

    <% let hasAction = false; %>
    <% if (user && user.role === 'Student') { %>
        <% if (hasAction) { %>|<% } %>
        <a href="/rsvp?_id=<%= event._id %>">RSVP</a>
        <% hasAction = true; %>
    <% } %>
    <!-- checks if user is logged in before showing report option -->
    <% if (user) { %>
        <!-- add | if there are previous actions -->
        <% if (hasAction) { %>|<% } %>
        <!-- builds the report link, sends the event's Mongo _id string: /report-event?_id=<event id> -->
        <a href="/report-event?_id=<%= event._id %>">Report</a>
        <!-- marks that this row has at least one action -->
        <% hasAction = true; %>
    <% } %>

    <% if (user) { %>
        <% if (hasAction) { %>|<% } %>
        <a href="/bookmarks/add/<%= event._id %>">Bookmark</a>
        <% hasAction = true; %>
    <% } %>


    <br><br>
<a href="/events">← Back to Events</a>

     <h2>Discussion Forum</h2>

    <% if (user && !userHasReview) { %>
        <form action="/review/create" method="POST">
            <input type="hidden" name="eventID" value="<%= event._id %>">

            <label>Comment:</label><br>
            <textarea name="comment" required></textarea><br><br>

            <button type="submit">Post Review</button>
        </form>
    <% } else if (user) { %>
        <p>You already posted a review for this event. Edit your existing review below.</p>
    <% } else { %>
        <p>You must be logged in to post a review.</p>
    <% } %>

    <hr>

    <!-- ===================== -->
    <!-- DISPLAY REVIEWS -->
    <!-- ===================== -->
    <h2>Reviews</h2>
    <% if(reviews!=[]){ %>
    <% reviews.forEach(review => { %>
        <div style="border:1px solid black; padding:10px; margin-bottom:10px;">

            <p><strong>User:</strong> <%= review.user && review.user.name ? review.user.name : 'Unknown user' %></p>
            <p><strong>Comment:</strong> <%= review.comment %></p>
            <p><strong>Posted:</strong> <%= new Date(review.createdAt).toLocaleString() %></p>

            <% if (review.edited) { %>
                <small>(edited)</small>
                <p><strong>Last updated:</strong> <%= new Date(review.updatedAt).toLocaleString() %></p>
            <% } %>

            <!-- ===================== -->
            <!-- UPDATE + DELETE (ONLY OWNER) -->
            <!-- ===================== -->
            <% if (user && review.user && String(review.user._id || review.user) === String(user.id)) { %>

                <!-- UPDATE -->
                <form action="/review/update/<%= review._id %>" method="POST">
                    <input type="text" name="comment" value="<%= review.comment %>">
                    <button type="submit">Update</button>
                </form>

                <!-- DELETE -->
                <form action="/review/delete/<%= review._id %>" method="POST">
                    <button type="submit">Delete</button>
                </form>

            <% } %>

        </div>
    <% })} %>
</body>
</html>
