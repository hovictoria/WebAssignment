<%- include("common/header") %>

    <h1>Profile</h1>
    <% if(!edit){ %>
    <table border="1">
        <tr>
            <td>Name: </td>
            <td><%=user.name%></td>
        </tr>
        <tr>
            <td>Email: </td>
            <td><%=user.email%></td>
        </tr>
        <tr>
            <td>Password: </td>
            <td>*******</td>
        </tr>
        <tr>
            <td>Role: </td>
            <td><%=user.role%></td>
        </tr>
        <tr>
            <td colspan="2"><a href="/profile?edit=<%=user.email%>">Edit</a> | <a href="/profile?delete=<%=user.email%>">Delete</a></td>
        </tr>
    </table>
    <%} else{ %>
    <form action="profileedit" method="post">
    <table border="1">
        <tr>
            <td>Name: </td>
            <td><input type="text" name="name" value="<%= user.name %>"></td>
        </tr>
        <tr>
            <td>Email: </td>
            <td><input type="text" name="email" value="<%= user.email %>" readonly></td>
        </tr>
        <tr>
            <td>Password: </td>
            <td><input type="text" name="password"></td>
        </tr>
        <tr>
            <td>Role: </td>
            <td><input type="text" name="role" value="<%= user.role %>" readonly></td>
        </tr>
    </table><br>
    <button type="submit">Update</button>
    <a href="/profile"><button type="button">Cancel</button></a>
    </form>
    <% } %>
    <% if(message){ %>
    <p><%= message %></p>
    <% } %>
    <% if (del) { %>
    <p><strong>⚠️ This action cannot be undone! Are you sure you want to delete this event?</strong></p>
    <form action="/profiledelete" method="POST">
        <input type="hidden" name="email" value="<%= user.email %>">
        <button type="submit">🗑️ Confirm Delete</button>
        <a href="/profile"><button type="button">Cancel</button></a>
    </form>
    <% } %>