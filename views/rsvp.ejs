<%- include("common/header") %>

<table width="700" align="center" border="1" cellpadding="12" cellspacing="0">
  <tr>
    <td align="left">
<h1>RSVP for Event</h1>

<% if (error) { %>
  <p style="color:red"><%= error %></p>
<% } %>

<% if (success) { %>
  <p style="color:green"><%= success %></p>
<% } %>

<h2><%= event.title %></h2>
<table border="1" cellpadding="8" cellspacing="0">
  <tr>
    <th>Date</th>
    <td><%= new Date(event.date).toDateString() %></td>
  </tr>
  <tr>
    <th>Time</th>
    <td><%= event.time || '-' %></td>
  </tr>
  <tr>
    <th>Location</th>
    <td><%= event.location %></td>
  </tr>
  <tr>
    <th>Category</th>
    <td><%= event.category %></td>
  </tr>
  <tr>
    <th>Description</th>
    <td><%= event.description %></td>
  </tr>
</table>

<hr>

<% if (myRsvp) { %>
  <form action="/rsvp/update-rsvp" method="POST" style="margin-bottom: 12px;">
    <input type="hidden" name="id" value="<%= myRsvp._id %>">
    <input type="hidden" name="eventId" value="<%= event._id %>">

    <label for="status">Status</label>
    <select name="status" id="status">
      <option value="Going" <%= myRsvp.status === 'Going' ? 'selected' : '' %>>Going</option>
      <option value="Maybe" <%= myRsvp.status === 'Maybe' ? 'selected' : '' %>>Maybe</option>
    </select>

    <br><br>

    <button type="submit">Update RSVP</button>
  </form>

  <form action="/rsvp/delete-rsvp" method="POST">
    <input type="hidden" name="id" value="<%= myRsvp._id %>">
    <input type="hidden" name="eventId" value="<%= event._id %>">
    <button type="submit">Delete RSVP</button>
  </form>
<% } else { %>
  <form action="/rsvp/create-rsvp" method="POST">
    <input type="hidden" name="eventId" value="<%= event._id %>">
    <label for="status">Status</label>
    <select name="status" id="status">
      <option value="Going">Going</option>
      <option value="Maybe">Maybe</option>
    </select>

    <br><br>

    <button type="submit">Confirm RSVP</button>
  </form>
<% } %>

<hr>

<h2>Attendees</h2>

<% if (!rsvps || rsvps.length === 0) { %>
  <p>No RSVPs yet.</p>
<% } else { %>
  <table border="1" cellpadding="8" cellspacing="0" style="width:100%; border-collapse:collapse;">
    <thead>
      <tr>
        <th>User</th>
        <th>Status</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% rsvps.forEach(rsvp => { %>
        <tr>
          <td><%= rsvp.user ? rsvp.user.name : "Deleted User" %></td>
          <td><%= rsvp.status %></td>
          <td><%= new Date(rsvp.rsvpDate).toDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<br>
<a href="/events">Back to Events</a>

    </td>
  </tr>
</table>
    </center>
</body>
</html>
