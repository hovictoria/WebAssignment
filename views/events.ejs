<%- include("common/header") %>

    <table width="80%" align="center">
        <tr>
            <td>
                <h1>Campus Events</h1>

                <a href="/events/create-event">Create Event</a>

                <hr>

                <form method="GET" action="/events">
                    <div>
                        <label for="keyword">Keyword:</label>
                        <input type="text" id="keyword" name="keyword" value="<%= keyword %>">
                    </div>

                    <br>

                    <div>
                        <label for="category">Category:</label>
                        <select id="category" name="category">
                            <option value="">All</option>
                            <option value="Academic" <%= category === 'Academic' ? 'selected' : '' %>>Academic</option>
                            <option value="Social" <%= category === 'Social' ? 'selected' : '' %>>Social</option>
                            <option value="Sports" <%= category === 'Sports' ? 'selected' : '' %>>Sports</option>
                            <option value="Workshop" <%= category === 'Workshop' ? 'selected' : '' %>>Workshop</option>
                            <option value="Other" <%= category === 'Other' ? 'selected' : '' %>>Other</option>
                        </select>
                    </div>

                    <br>

                    <div>
                        <label for="location">Location:</label>
                        <input type="text" id="location" name="location" value="<%= location %>">
                    </div>

                    <br>

                    <div>
                        <label for="date">Date:</label>
                        <input type="date" id="date" name="date" value="<%= date %>">
                    </div>

                    <br>

                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <div>
                            <button type="submit">Search / Filter</button>
                            <a href="/events">Clear</a>
                        </div>
                        <div>
                            <label for="sortBy">Sort by:</label>
                            <select id="sortBy" name="sortBy" onchange="this.form.submit()">
                                <option value="dateDesc" <%= sortBy === 'dateDesc' ? 'selected' : '' %>>Newest to Oldest</option>
                                <option value="dateAsc" <%= sortBy === 'dateAsc' ? 'selected' : '' %>>Oldest to Newest</option>
                                <option value="title" <%= sortBy === 'title' ? 'selected' : '' %>>Title (A-Z)</option>
                                <option value="titleDesc" <%= sortBy === 'titleDesc' ? 'selected' : '' %>>Title (Z-A)</option>
                            </select>
                        </div>
                    </div>
                </form>

                <hr>
            </td>
        </tr>
    </table>

    <% if (events.length === 0) { %>
        <p>No events found.</p>
    <% } else { %>
        <table border="1" cellpadding="8" cellspacing="0" style="width:80%; border-collapse:collapse; margin: 0 auto;">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name of Event</th>
                    <th>Date</th>
                    <th>Category</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% events.forEach(event => { %>
                    <tr>
                        <td style="text-align: center;">
                            <% if (event.imageUrl) { %>
                                <img src="<%= event.imageUrl %>" width="100">
                            <% } else { %>
                                <img src="/images/default.jpg" width="100">
                            <% } %>
                        </td>
                        <td><%= event.title %></td>
                        <td>
                            <%= new Date(event.date).toDateString() %><br>
                            <% if (event.status === 'Upcoming') { %>
                                <span style="color: green;">● Upcoming</span>
                            <% } else if (event.status === 'Ongoing') { %>
                                <span style="color: orange;">● Ongoing</span>
                            <% } else { %>
                                <span style="color: grey;">● Past</span>
                            <% } %>
                        </td>
                        <td><%= event.category %></td>
                        <td>
                            <% const canEdit = user && event.status !== 'Past' && (user.role === 'Admin' || String(event.organiser) === String(user.id)); %>
                            <% const canDelete = user && event.status !== 'Past' && (user.role === 'Admin' || String(event.organiser) === String(user.id)); %>
                            <% let hasAction = false; %>
                            <a href="/events/event-details?_id=<%= event._id %>">Details</a>
                            <% if (canEdit) { %>
                                | <a href="/events/update-event?_id=<%= event._id %>">Edit</a>
                                <% hasAction = true; %>
                            <% } %>
                            <% if (canDelete) { %>
                                <% if (hasAction) { %>|<% } %>
                                <a href="/events/delete-event?_id=<%= event._id %>">Delete</a>
                            <% } %>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>

    </center>
</body>
</html>
