<%- include("common/header") %>
    <table width="700" align="center" border="1" cellpadding="12" cellspacing="0">
        <tr>
            <td align="left">

    <h1>Edit Event</h1>

    <% if (error !== '') { %>
        <p style="color:red">⚠️ <%= error %></p>
    <% } %>

    <% if (success === '' && Object.keys(result).length !== 0) { %>
        <form action="/events/update-event" method="post" enctype="multipart/form-data">
            <table>
                <tr>
                    <th align="left"><label for="title">Title:</label></th>
                    <td><input type="text" id="title" name="title" value="<%= result.title %>"></td>
                </tr>
                <tr>
                    <th align="left"><label for="date">Date:</label></th>
                    <td><input type="date" id="date" name="date" value="<%= date %>"></td>
                </tr>
                <tr>
                    <th align="left"><label for="time">Time:</label></th>
                    <td><input type="time" id="time" name="time" value="<%= result.time || '' %>"></td>
                </tr>
                <tr>
                    <th align="left"><label for="location">Location:</label></th>
                    <td><input type="text" id="location" name="location" value="<%= result.location %>"></td>
                </tr>
                <tr>
                    <th align="left"><label for="category">Category:</label></th>
                    <td>
                        <select id="category" name="category">
                            <option value="" <%= result.category === '' ? 'selected' : '' %>>--Select a Category--</option>
                            <option value="Academic" <%= result.category === 'Academic' ? 'selected' : '' %>>Academic</option>
                            <option value="Social" <%= result.category === 'Social' ? 'selected' : '' %>>Social</option>
                            <option value="Sports" <%= result.category === 'Sports' ? 'selected' : '' %>>Sports</option>
                            <option value="Workshop" <%= result.category === 'Workshop' ? 'selected' : '' %>>Workshop</option>
                            <option value="Other" <%= result.category === 'Other' ? 'selected' : '' %>>Other</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <th align="left"><label>Event Image <br>(optional):</label></th>
                    <td><% if (result.imageUrl) { %>
                            <img src="<%= result.imageUrl %>" width="200"><br>
                            <small>Current image — upload a new one to replace it</small><br>
                        <% } %>
                        <input type="file" name="image" accept="image/*">
                    </td>
                </tr>
                <tr>
                    <th align="left"><label for="description">Description:</label></th>
                    <td><textarea id="description" name="description" rows="5" cols="40"><%= result.description %></textarea></td>
                </tr>
            </table>
            <br>
            <input type="hidden" name="_id" value="<%= result._id %>">
            <button type="submit">💾 Update Event</button>
        </form>
    <% } %>

    <% if (success !== '') { %>
        <p style="color:green">✅ <%= success %></p>
    <% } %>
    <br>
    <a href="/events">← Back to Events</a>

            </td>
        </tr>
    </table>
</body>
</html>
