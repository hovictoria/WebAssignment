<%- include("common/header") %>
  <% const students = data.filter(account => account.role === 'Student'); %>
  <% const admins = data.filter(account => account.role === 'Admin'); %>
  <h1>Welcome, <%= user.name %> 👋</h1>

  <hr>

  <h2>🚩 Reports</h2>
  <p>
    <a href="/reports">View Reports</a>
  </p>

  <hr>

  <div class="container mt-5">
    <h2>Students (<%= students.length %>)</h2>
    <table border="1">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Password</th>
        <th>Role</th>
        <th colspan="2">Actions</th>
        
      </tr>
      <% students.forEach(user => {%>
        <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td>********</td>
            <td><%= user.role %></td>
            <td><a href="/admin?email=<%= user.email %>#editform">Edit</a> | <a href="/admin?delete=<%= user.email %>">Delete</a></td>
        </tr>
      <%}); %>
    </table>
    
  </div>

  <br>

  <div class="container mt-5">
    <h2>Admins (<%= admins.length-1 %>)</h2>
    <table border="1">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Password</th>
        <th>Role</th>
        <th colspan="2">Actions</th>
      </tr>
      <% admins.forEach(admin => {%>
        <% if(admin.email!=user.email){ %>
        <tr>
            <td><%= admin.name %></td>
            <td><%= admin.email %></td>
            <td>********</td>
            <td><%= admin.role %></td>
            <td><a href="/admin?email=<%= admin.email %>#editform">Edit</a> | <a href="/admin?delete=<%= admin.email %>#confirmdelete">Delete</a></td>
        </tr>
        <% } %>
      <%}); %>
    </table>
  </div>
  <div id="progress">
    <a href="login.html" id="progress-value"><i class='bx bx-left-arrow-alt'></i></a>
  </div>


<% if(edit){ %>
    <div id="editform">

    <h4>Edit User</h4>
    
      <form action="edit-user" method="post">
        <table>
        <tr>
          <td>Name:*</td>
          <td><input type="text" name="name" value="<%= edit.name %>"></td>
        </tr>
        <tr>
          <td>Email: </td>
          <td><input type="email" name="email" value="<%= edit.email %>" readonly></td>
        </tr>
        <tr>
          <td>Password: </td>
          <td><input type="text" name="password" placeholder="leave empty if no change"></td>
        </tr>
        <tr>
          <td>Role:*</td>
          <td>  
          <select name="role" class="form-control">
            <option value="Student" <%=edit.role=="Student"? "selected" : ""%>>Student</option>
            <option value="Admin" <%=edit.role=="Admin"? "selected" : ""%>>Admin</option>
          </select></td>
        </tr>
          </table><br>
          <button type="submit">Update</button>
        </form>
        
    </table>
        
        
    </div>

  <% } %>
  <% if (del) { %>
    <div id="confirmdelete">
      <p><strong>⚠️ This action cannot be undone! Are you sure you want to delete this event?</strong></p>
    <form action="/delete-user" method="get">
        <input type="hidden" name="email" value="<%= del %>">
        <button type="submit">🗑️ Confirm Delete</button>
        <a href="/admin"><button type="button">Cancel</button></a>
    </form>
    </div>
  <% } %>
  <% if(error){ %>
    <p style="color:red"><%= error %></p>
    <% } %>
  <% if(success){ %>
    <p style="color:green"><%= success %></p>
    <% } %>
</body>
</html>