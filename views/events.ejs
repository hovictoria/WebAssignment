<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Events</title>
</head>
<body>

  <h1>Campus Events</h1>
  <a href="/create-event">+ Create New Event</a> <br><br>

  <% if (error !== '') { %>
    <p style="color:red">⚠️ <%= error %></p>
  <% } else { %>
    <table border="1">
      <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Date</th>
        <th>Location</th>
        <th>Category</th>
        <th>Edit</th>
        <th>Delete</th>
      </tr>

      <% for (let e of eventlist) { %>
      <tr>
        <td><%= e.title %></td>
        <td><%= e.description %></td>
        <td><%= new Date(e.date).toLocaleDateString('en-SG') %></td>
        <td><%= e.location %></td>
        <td><%= e.category %></td>
        <td><a href="/update-event?_id=<%= e._id %>">Edit</a></td>
        <td><a href="/delete-event?_id=<%= e._id %>">Delete</a></td>
      </tr>
      <% } %>
    </table>
  <% } %>

</body>
</html>
