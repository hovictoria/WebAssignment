<%- include("common/header") %>
    <center>
    <table width="700" align="center" border="1" cellpadding="12" cellspacing="0">
        <tr>
            <td align="left">

    <h1><%= event.title %></h1>
    <% if (event.imageUrl) { %>
        <img src="<%= event.imageUrl %>" width="300">
    <% } else { %>
        <img src="/images/default.jpg" width="300">
    <% } %>
                        
    <br><br>
    <a href="/events">← Back to Events</a>
    <br><br>

    <table border="1" cellpadding="8" cellspacing="0" style="width:80%; border-collapse:collapse;">
        <tr>
            <th align="left"><label>Date</label></th>
            <td><%= new Date(event.date).toDateString() %></td>
        </tr>
        <tr>
            <th align="left"><label>Time</label></th>
            <td><%= event.time || '-' %></td>
        </tr>
        <tr>
            <th align="left"><label>Location</label></th>
            <td><%= event.location %></td>
        </tr>
        <tr>
            <th align="left"><label>Category</label></th>
            <td><%= event.category %></td>
        </tr>
        <tr>
            <th align="left"><label>Organiser</label></th>
            <td><%= organiser.name %></td>
        </tr>
        <tr>
            <th align="left"><label>Description</label></th>
            <td><%= event.description %></td>
        </tr>
    </table>
    <br>

    <% let hasAction = false; %>
    <% if (user && user.role === 'Student') { %>
        <% if (hasAction) { %>|<% } %>
        <a href="/rsvp?_id=<%= event._id %>">RSVP</a>
        <% hasAction = true; %>
    <% } %>
    <% if (user) { %>
        <% if (hasAction) { %>|<% } %>
        <a href="/bookmarks/add/<%= event._id %>">Bookmark</a>
        <% hasAction = true; %>
    <% } %>
    <% if (user) { %>
        <% if (hasAction) { %>|<% } %>
        <a href="/report-event?_id=<%= event._id %>">Report</a>
        <% hasAction = true; %>
    <% } %>

    <br><br>

    <h2>Discussion Forum</h2>

    <% if (user) { %>
        <form action="/review/create" method="POST">
            <input type="hidden" name="eventID" value="<%= event._id %>">
            <label for="comment">Comment:</label><br>
            <textarea id="comment" name="comment" required></textarea><br><br>
            <button type="submit">Post Comment</button>
        </form>
    <% } else { %>
        <p>You must be logged in to post a comment.</p>
    <% } %>

    <hr>

    <h2 align="center">Reviews</h2>
    <% reviews.forEach(review => { %>
        <div style="border:1px solid black; padding:10px; margin-bottom:10px;">
            <p><strong>User:</strong> <%= review.user && review.user.name ? review.user.name : 'Unknown user' %></p>
            <p><strong>Comment:</strong> <%= review.comment %> <% if (review.edited) { %><small>(edited)</small><% } %></p>
            <p><strong>Posted:</strong> <%= new Date(review.createdAt).toLocaleString() %></p>
            <% if (review.edited) { %>
                <p><strong>Last updated:</strong> <%= new Date(review.updatedAt).toLocaleString() %></p>
            <% } %>
            <% if (user && review.user && String(review.user._id || review.user) === String(user.id)) { %>
                <form action="/review/update/<%= review._id %>" method="POST">
                    <label for="edit-comment-<%= review._id %>" style="display:inline-block; vertical-align: top;"><strong>Edit:</strong></label>
                    <textarea id="edit-comment-<%= review._id %>" name="comment" rows="4" cols="50"><%= review.comment %></textarea>
                    <button type="submit">Update</button>
                </form>
                <form action="/review/delete/<%= review._id %>" method="POST">
                    <button type="submit">Delete</button>
                </form>
            <% } %>
        </div>
    <% }); %>
            </td>
        </tr>
    </table>

    </center>
</body>
</html>
