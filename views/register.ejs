<%- include("common/header") %>
   
<div style="padding-left: 40%; padding-right: 40%;">
    <table cellpadding="12" cellspacing="0" width="100%">
        <tr><td>
            <h1>Register</h1>
            <form action="/user/register" method="post">
                <label for="name">Name: </label><br>
                <input type="text" size="25" name="name" placeholder="Enter name" value="<%=name%>"><br><br>

                <label for="email">Email: </label><br>
                <input type="email" size="25" name="email" placeholder="Enter email" value="<%=email%>"><br><br>
                
                <label for="password">Password:</label><br>
                <input type="password" size="25" name="password" placeholder="Enter password"><br><br>
                
                <label for="confirmPassword">Confirm Password:</label><br>
                <input type="password" size="25" name="confirmpassword" placeholder="Confirm password"><br><br>

                <label for="role">Register As:</label><br>
                <select name="role" id="role">
                    <option value="Student" <%= role === 'Student' ? 'selected' : '' %>>Student</option>
                    <option value="Admin" <%= role === 'Admin' ? 'selected' : '' %>>Admin</option>
                </select><br><br>

                <button type="submit">Register</button><br><br>

                <span>Registered? </span><a href="/user/login">Log In!</a>

            </form>
            <% if(errors!=""){ %>
                <p style="color:red"><%= errors %></p>
            <% } %>
        </td></tr>
    </table>
    </div>
</center>
</body>
</html>
